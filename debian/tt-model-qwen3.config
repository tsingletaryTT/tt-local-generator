#!/bin/sh
# debian/tt-model-qwen3.config — debconf pre-configuration for Qwen3-0.6B
#
# Qwen3-0.6B is fully public — no token or account is required.
# This script still runs the token discovery sequence so that a token
# found elsewhere (e.g. already answered for a gated model in the same
# apt install run) is available for rate-limit avoidance.
#
# Critically: the debconf field is always marked seen=true, so the
# interactive prompt is NEVER shown for this package. The HF token
# is purely optional here.
#
# All four tt-model-* packages share the key 'tt-local-generator/hf-token'.

set -e

. /usr/share/debconf/confmodule

db_version 2.0

# ── Token search (optional — for rate-limit avoidance only) ───────────────────
_TOKEN=""

# 1. $HF_TOKEN environment variable
if [ -n "${HF_TOKEN:-}" ]; then
    _TOKEN="$HF_TOKEN"
fi

# 2. $HUGGING_FACE_HUB_TOKEN environment variable
if [ -z "$_TOKEN" ] && [ -n "${HUGGING_FACE_HUB_TOKEN:-}" ]; then
    _TOKEN="$HUGGING_FACE_HUB_TOKEN"
fi

_HOME="${HOME:-/root}"
if [ -n "${SUDO_USER:-}" ] && [ "$SUDO_USER" != "root" ]; then
    _HOME="/home/$SUDO_USER"
fi
_HF_HOME="${HF_HOME:-$_HOME/.cache/huggingface}"

# 3. ${HF_HOME}/token
if [ -z "$_TOKEN" ] && [ -f "$_HF_HOME/token" ]; then
    _TOKEN="$(cat "$_HF_HOME/token")"
fi

# 4. ~/.huggingface/token
if [ -z "$_TOKEN" ] && [ -f "$_HOME/.huggingface/token" ]; then
    _TOKEN="$(cat "$_HOME/.huggingface/token")"
fi

# 5. /etc/tt-generator/hf_token
if [ -z "$_TOKEN" ] && [ -f "/etc/tt-generator/hf_token" ]; then
    _TOKEN="$(cat /etc/tt-generator/hf_token)"
fi

# ── Always pre-populate and suppress the prompt ────────────────────────────────
# Qwen3 is public: no token is required. If we found one, set it for the
# benefit of rate-limit avoidance; if not, leave the field empty.
# Either way, mark the field seen=true so debconf never prompts.
if [ -n "$_TOKEN" ]; then
    db_set tt-local-generator/hf-token "$_TOKEN"
fi
db_fset tt-local-generator/hf-token seen true
