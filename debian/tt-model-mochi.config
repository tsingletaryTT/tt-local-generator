#!/bin/sh
# debian/tt-model-mochi.config — debconf pre-configuration for Mochi-1-preview
#
# Mochi-1-preview is publicly available. A token is optional but recommended
# to avoid API rate limits. This script follows the same token discovery
# pattern as the other tt-model-* packages.
#
# All four tt-model-* packages share the key 'tt-local-generator/hf-token'.

set -e

. /usr/share/debconf/confmodule

db_version 2.0

# ── Token search ───────────────────────────────────────────────────────────────
_TOKEN=""

# 1. $HF_TOKEN environment variable
if [ -n "${HF_TOKEN:-}" ]; then
    _TOKEN="$HF_TOKEN"
fi

# 2. $HUGGING_FACE_HUB_TOKEN environment variable
if [ -z "$_TOKEN" ] && [ -n "${HUGGING_FACE_HUB_TOKEN:-}" ]; then
    _TOKEN="$HUGGING_FACE_HUB_TOKEN"
fi

_HOME="${HOME:-/root}"
if [ -n "${SUDO_USER:-}" ] && [ "$SUDO_USER" != "root" ]; then
    _HOME="/home/$SUDO_USER"
fi
_HF_HOME="${HF_HOME:-$_HOME/.cache/huggingface}"

# 3. ${HF_HOME}/token
if [ -z "$_TOKEN" ] && [ -f "$_HF_HOME/token" ]; then
    _TOKEN="$(cat "$_HF_HOME/token")"
fi

# 4. ~/.huggingface/token
if [ -z "$_TOKEN" ] && [ -f "$_HOME/.huggingface/token" ]; then
    _TOKEN="$(cat "$_HOME/.huggingface/token")"
fi

# 5. /etc/tt-generator/hf_token
if [ -z "$_TOKEN" ] && [ -f "/etc/tt-generator/hf_token" ]; then
    _TOKEN="$(cat /etc/tt-generator/hf_token)"
fi

# ── Debconf preseed or prompt ──────────────────────────────────────────────────
if [ -n "$_TOKEN" ]; then
    db_set tt-local-generator/hf-token "$_TOKEN"
    db_fset tt-local-generator/hf-token seen true
else
    db_input medium tt-local-generator/hf-token || true
    db_go || true
fi
