Package: tt-local-generator
Architecture: amd64
Depends:
 python3 (>= 3.10),
 python3-gi,
 python3-gi-cairo,
 gir1.2-gtk-4.0,
 python3-requests,
 ffmpeg,
 libgtk-4-media-gstreamer,
 gstreamer1.0-plugins-base,
 gstreamer1.0-plugins-good,
 gstreamer1.0-plugins-bad,
 gstreamer1.0-libav,
