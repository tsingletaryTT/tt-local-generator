#!/bin/bash
# debian/prerm — pre-removal script for tt-local-generator
#
# Stops any managed services before the package files are removed.
# This prevents dangling processes or missing-binary errors if the user
# left the inference server running.

set -euo pipefail

TT_CTL="/usr/lib/tt-local-generator/tt-ctl"

case "$1" in
    remove|deconfigure)
        # Stop all managed services gracefully only on actual removal.
        # Skipped during upgrade so a running inference server is not killed
        # just because the user is reinstalling or updating the package.
        if [[ -x "$TT_CTL" ]]; then
            echo "tt-local-generator: stopping managed services…"
            "$TT_CTL" stop all 2>/dev/null || true
            "$TT_CTL" stop prompt-server 2>/dev/null || true
            echo "tt-local-generator: services stopped."
        fi
        ;;
    upgrade|failed-upgrade)
        # Nothing to do — leave inference servers running across upgrades.
        ;;
    *)
        # Unexpected argument — do nothing rather than fail.
        ;;
esac

exit 0
