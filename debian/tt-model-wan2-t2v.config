#!/bin/sh
# debian/tt-model-wan2-t2v.config — debconf pre-configuration for Wan2.2-T2V
#
# Runs before package unpacking. Searches for a HuggingFace token in
# well-known locations; if found, pre-populates the debconf key so the
# user is not prompted. If not found, asks at medium priority.
#
# All four tt-model-* packages share the key 'tt-local-generator/hf-token'.
# debconf merges duplicate keys by name, so when multiple packages are
# installed together the token is requested at most once.

set -e

# Load the debconf shell API.
. /usr/share/debconf/confmodule

db_version 2.0

# ── Token search ───────────────────────────────────────────────────────────────
# We inspect common locations before falling through to the interactive prompt.

_TOKEN=""

# 1. $HF_TOKEN environment variable
if [ -n "${HF_TOKEN:-}" ]; then
    _TOKEN="$HF_TOKEN"
fi

# 2. $HUGGING_FACE_HUB_TOKEN environment variable
if [ -z "$_TOKEN" ] && [ -n "${HUGGING_FACE_HUB_TOKEN:-}" ]; then
    _TOKEN="$HUGGING_FACE_HUB_TOKEN"
fi

# Determine a best-guess HOME for file searches.
# When running as root (sudo apt install), SUDO_USER points to the real user.
_HOME="${HOME:-/root}"
if [ -n "${SUDO_USER:-}" ] && [ "$SUDO_USER" != "root" ]; then
    _HOME="/home/$SUDO_USER"
fi
_HF_HOME="${HF_HOME:-$_HOME/.cache/huggingface}"

# 3. ${HF_HOME}/token — written by 'huggingface-cli login'
if [ -z "$_TOKEN" ] && [ -f "$_HF_HOME/token" ]; then
    _TOKEN="$(cat "$_HF_HOME/token")"
fi

# 4. ~/.huggingface/token — legacy location
if [ -z "$_TOKEN" ] && [ -f "$_HOME/.huggingface/token" ]; then
    _TOKEN="$(cat "$_HOME/.huggingface/token")"
fi

# 5. /etc/tt-generator/hf_token — admin-staged / CI path
if [ -z "$_TOKEN" ] && [ -f "/etc/tt-generator/hf_token" ]; then
    _TOKEN="$(cat /etc/tt-generator/hf_token)"
fi

# ── Debconf preseed or prompt ──────────────────────────────────────────────────
if [ -n "$_TOKEN" ]; then
    # Token found — pre-populate and mark as seen to skip the interactive prompt.
    db_set tt-local-generator/hf-token "$_TOKEN"
    db_fset tt-local-generator/hf-token seen true
else
    # No token found — ask the user (medium priority, skipped in noninteractive).
    db_input medium tt-local-generator/hf-token || true
    db_go || true
fi
