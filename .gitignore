__pycache__/
*.py[cod]
*.swp
.DS_Store
.venv/
.superpowers/
.worktrees/
prompts/markov_output.txt
batch_generate.log

# Vendored tt-inference-server shallow clone.
# The pinned commit SHA is tracked in vendor/VENDOR_SHA.
# The checkout itself is not committed (large; regenerated by bin/setup_vendor.sh).
vendor/tt-inference-server/

# Docker image archive (~7.9 GB) — too large for GitHub LFS (2 GB limit).
# Distribute separately (SCP, rsync, direct download).
docker/*.tar.gz
docker/*.tar

# dpkg-buildpackage build artifacts (generated by debhelper during build).
# These are build-time outputs, not source — never commit them.
debian/.debhelper/
debian/debhelper-build-stamp
debian/files
debian/*.debhelper.log
debian/*.substvars
debian/*.postrm.debhelper
debian/tt-local-generator/
debian/tt-model-wan2-t2v/
debian/tt-model-flux/
debian/tt-model-mochi/
debian/tt-model-qwen3/
