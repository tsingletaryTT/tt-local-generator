# tt-local-generator — example environment configuration
#
# Copy this file to .env (not currently auto-loaded; values are shown
# here as documentation for what the tool expects to find in adjacent repos).
#
# ── Inference server connection ───────────────────────────────────────────────
#
# The UI connects to a locally-running tt-inference-server.
# Pass the URL at startup:
#   /usr/bin/python3 main.py --server http://localhost:8000
#
# Default: http://localhost:8000
# SERVER_URL=http://localhost:8000

# ── Authentication ─────────────────────────────────────────────────────────────
#
# api_client.py reads the API key automatically from:
#   ~/code/tt-inference-server/.env  →  AUTHORIZATION_TOKEN or API_KEY
#
# Set the same key in tt-inference-server's .env:
#   AUTHORIZATION_TOKEN=your-secret-token-here
#
# If neither key is present, the client falls back to the server's built-in
# default ("your-secret-key") which matches a server started with --no-auth.

# ── tt-inference-server .env (set in ~/code/tt-inference-server/.env) ─────────
#
# JWT_SECRET=<long random string>          — server JWT signing secret
# AUTHORIZATION_TOKEN=<long random string> — API key the UI reads for auth
# HF_TOKEN=<your HuggingFace token>        — required to download gated models
